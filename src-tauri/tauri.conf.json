{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QlipLab",
  "version": "0.1.0",
  "identifier": "com.qliplab.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [{
      "title": "QlipLab",
      "width": 480,
      "height": 460,
      "minWidth": 350,
      "minHeight": 300,
      "resizable": true,
      "decorations": false,
      "transparent": true,
      "skipTaskbar": true,
      "visibleOnAllWorkspaces": true,
      "center": true,
      "visible": false
    }],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost https://celikomr--8290084cf41111f0b7d742dde27851f2.web.val.run https://cdn.jsdelivr.net https://api.anthropic.com https://api.openai.com; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["icons/32x32.png"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./Entitlements.plist"
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
